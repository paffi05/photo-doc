{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for app windows",
  "windows": ["main", "import_wizard_helper", "import_wizard_preview", "image_preview"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "updater:default"
  ]
}
