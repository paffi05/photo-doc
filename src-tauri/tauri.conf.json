{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "medical-photo-manager",
  "version": "0.1.0",
  "identifier": "com.clemens.medical-photo-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  }, 
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "medical-photo-manager",
        "width": 900,
        "height": 600,
        "minWidth": 300,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
